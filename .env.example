NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for the Users page (src/app/api/admin/users/*): creating/inviting
# users, changing roles, disabling accounts, sending password resets.
# Server-only - NEVER prefix with NEXT_PUBLIC_, never commit the real value.
# Find it in Supabase: Project Settings -> API -> service_role secret key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OCR for Sales image uploads. GEMINI_API_KEY is read server-side only
# (in src/app/api/ocr/sales/route.ts) and must never be exposed to the client.
OCR_PROVIDER=gemini-vision
GEMINI_API_KEY=your-gemini-api-key
GEMINI_OCR_MODEL=gemini-2.0-flash

# Optional: require a shared password before allowing uploads.
UPLOAD_PASSWORD=
