generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model sales_raw_files {
  id          String   @id
  file_name   String
  file_url    String
  uploaded_at DateTime
  report_date String
  ocr_status  String
  created_at  DateTime @default(now())
}

model sales_by_salesperson {
  id               String   @id
  report_date      String
  salesperson_name String
  salesperson_code String
  morning_orders   Int      @default(0)
  morning_revenue  Float    @default(0)
  evening_orders   Int      @default(0)
  evening_revenue  Float    @default(0)
  total_orders     Int      @default(0)
  total_revenue    Float    @default(0)
  source_file_id   String
  created_at       DateTime @default(now())
}

model sales_by_platform {
  id              String   @id
  report_date     String
  platform_name   String
  morning_orders  Int      @default(0)
  morning_revenue Float    @default(0)
  evening_orders  Int      @default(0)
  evening_revenue Float    @default(0)
  total_orders    Int      @default(0)
  total_revenue   Float    @default(0)
  source_file_id  String
  created_at      DateTime @default(now())
}

model ads_raw_files {
  id             String   @id
  file_name      String
  file_url       String
  uploaded_at    DateTime
  report_date    String
  ads_platform   String
  sales_platform_name String   @default("غير محدد")
  parsing_status String
  created_at     DateTime @default(now())
}

model meta_ads {
  id             String   @id
  report_date    String
  sales_platform_name String @default("غير محدد")
  campaign_name  String
  adset_name     String
  ad_name        String
  spend          Float    @default(0)
  impressions    Int      @default(0)
  reach          Int      @default(0)
  clicks         Int      @default(0)
  ctr            Float    @default(0)
  cpc            Float    @default(0)
  cpm            Float    @default(0)
  leads          Int      @default(0)
  purchases      Int      @default(0)
  purchase_value Float    @default(0)
  source_file_id String
  created_at     DateTime @default(now())
}

model tiktok_ads {
  id                  String   @id
  report_date         String
  sales_platform_name String   @default("غير محدد")
  campaign_name       String
  adgroup_name        String
  ad_name             String
  spend               Float    @default(0)
  impressions         Int      @default(0)
  clicks              Int      @default(0)
  ctr                 Float    @default(0)
  cpc                 Float    @default(0)
  cpm                 Float    @default(0)
  conversions         Int      @default(0)
  cost_per_conversion Float    @default(0)
  revenue             Float    @default(0)
  source_file_id      String
  created_at          DateTime @default(now())
}

model platform_settings {
  id            String   @id
  platform_name String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
}

model daily_summary {
  id                   String   @id
  report_date          String   @unique
  total_sales_revenue  Float    @default(0)
  total_orders         Int      @default(0)
  total_ads_spend      Float    @default(0)
  meta_spend           Float    @default(0)
  tiktok_spend         Float    @default(0)
  roas                 Float?
  roi                  Float?
  cpa                  Float?
  average_order_value  Float?
  spend_to_sales_ratio Float?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
}
